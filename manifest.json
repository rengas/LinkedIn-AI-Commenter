{
  "manifest_version": 3,
  "name": "LinkedIn AI Commenter",
  "version": "2.0",
  "description": "Auto-generate LinkedIn comments using a local Ollama model.",
  "icons": {
    "16": "app_icon.png",
    "48": "app_icon.png",
    "128": "app_icon.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "options_page": "settings.html",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/*",
        "https://linkedin.com/*",
        "https://*.linkedin.com/*"
      ],
      "js": [
        "linkedin-probe-blocker.js"
      ],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    },
    {
      "matches": [
        "https://www.linkedin.com/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "action": {
    "default_popup": "options.html",
    "default_icon": {
      "16": "app_icon.png",
      "48": "app_icon.png",
      "128": "app_icon.png"
    }
  }
}