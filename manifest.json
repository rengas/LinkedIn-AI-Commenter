{
  "manifest_version": 3,
  "name": "LinkedIn AI Commenter",
  "version": "1.0",
  "description": "Auto-generate LinkedIn comments using Gemini AI.",
  "icons": {
    "16": "app_icon.png",
    "48": "app_icon.png",
    "128": "app_icon.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://generativelanguage.googleapis.com/*",
    "https://linkedin-ai-proxy.info-rana012.workers.dev/*"
  ],
  "options_page": "options.html",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ]
    }
  ],
  "action": {
    "default_popup": "options.html",
    "default_icon": {
      "16": "app_icon.png",
      "48": "app_icon.png",
      "128": "app_icon.png"
    }
  }
}